# Google Maps API Key
# GCPコンソール → APIとサービス → 認証情報 で取得
# 本番環境では必ずHTTPリファラー制限を設定すること
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Google Maps Map ID（AdvancedMarkerに必須）
# GCPコンソール → Google Maps Platform → Map Management で作成
# 未設定時はMapView.tsxが"DEMO_MAP_ID"にフォールバックする（本番では要設定）
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id_here

# Supabase（プロジェクト作成後に設定）
# https://supabase.com → プロジェクト Settings > API で確認
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# スマレジ Webhook 署名シークレット
# スマレジ開発者ポータル → Webhooks → 署名シークレット で取得
# Webhook URL: https://valuesip.jp/api/webhooks/smaregi
SMAREGI_WEBHOOK_SECRET=your_smaregi_webhook_secret_here
